executor.name = 'google-batch'

google {
    enableRequesterPaysBuckets = true
    location                   = 'europe-west1'
    project                    = 'open-targets-genetics-dev'

    batch {
        spot            = true
        maxSpotAttempts = 1
    }
}

workDir = 'gs://vidra-2-0/nextflow/work'

params {
    input               = 'gs://vidra-2-0/vidra_results/part-00000-fd81a532-8f91-4c64-96bd-7ac193456489-c000.snappy.parquet'
    outdir              = 'gs://vidra-2-0/nextflow/results'
    trace_report_suffix = 'google_cloud_test'
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline/execution_timeline_${params.trace_report_suffix}.html"
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report/execution_report_${params.trace_report_suffix}.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace/execution_trace_${params.trace_report_suffix}.txt"
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag/pipeline_dag_${params.trace_report_suffix}.html"
}

process {
    withLabel: process_single {
        // In the future, this image is built and pushed by .github/workflows/build-image.yaml. 

        // For now, we build and push it manually with:
        // gcloud auth configure-docker europe-west1-docker.pkg.dev
        // gcloud builds submit --tag europe-west1-docker.pkg.dev/open-targets-genetics-dev/opentargets/headtext:latest .
        // gcloud artifacts docker images list europe-west1-docker.pkg.dev/open-targets-genetics-dev/opentargets

        // Build and push an amd64 image that contains Java plus PySpark and /app/tools/headtext.py.
        container   = 'europe-west1-docker.pkg.dev/open-targets-genetics-dev/opentargets/headtext:latest'

        // Minimal practical Batch footprint for this task:
        cpus        = 1
        memory      = '3 GB'
        machineType = 'e2-standard-2'
        time        = '5m'
        maxRetries  = 1
        disk        = '10.GB'

        // Required for Spark because it cannot read symlinked staged files reliably.
        stageInMode = 'copy'
    }
}
